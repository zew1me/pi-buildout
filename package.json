{
  "name": "pi-local-customizations",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local pi extensions, runtime patches, and supporting notes",
  "engines": {
    "node": ">=22.19.0"
  },
  "packageManager": "npm@11.17.0",
  "scripts": {
    "prepare": "lefthook install",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "npm run lint:eslint && npm run lint:markdown && npm run lint:shell",
    "lint:eslint": "eslint . --max-warnings 0",
    "lint:markdown": "markdownlint-cli2 \"**/*.md\"",
    "lint:shell": "shellcheck scripts/*.sh",
    "typecheck": "tsc --noEmit",
    "test": "node --test --test-skip-pattern='real Bifrost routing evaluation' 'extensions/**/*.test.mjs'",
    "test:eval:real": "node --test extensions/router/eval/real.test.mjs",
    "knip": "knip",
    "secrets": "secretlint \"**/*\"",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm test && npm run knip && npm run secrets",
    "audit": "npm audit --audit-level=high"
  },
  "devDependencies": {
    "@earendil-works/pi-agent-core": "0.80.7",
    "@earendil-works/pi-ai": "0.80.7",
    "@earendil-works/pi-coding-agent": "0.80.7",
    "@earendil-works/pi-tui": "0.80.7",
    "@eslint/js": "^9.39.5",
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.2",
    "@types/node": "^24.0.0",
    "eslint": "^9.39.5",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.2.0",
    "eslint-plugin-unicorn": "^65.0.0",
    "globals": "^16.5.0",
    "knip": "^6.27.0",
    "lefthook": "^2.1.10",
    "markdownlint-cli2": "^0.23.0",
    "prettier": "^3.6.0",
    "prettier-plugin-sh": "^0.19.0",
    "secretlint": "^13.0.2",
    "typebox": "1.1.38",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0"
  }
}
