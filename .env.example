# Copy to .env.bifrost.local for local real-provider router evaluations.
# Never commit a real virtual key.
BIFROST_BASE_URL=https://your-bifrost-host.example
BIFROST_VIRTUAL_KEY=replace-with-a-ci-or-evaluation-scoped-virtual-key

# Optional limits for a cheaper canary before the full 11-archetype run.
# ROUTER_EVAL_LIMIT=1
# ROUTER_EVAL_PROFILE_LIMIT=1
